*.env
*ost-config.php
osTicket/upload/setup_disabled_*
osTicket/upload/include/ost-config.php
osTicket/upload/attachments/*
!osTicket/upload/attachments/.gitkeep

# Ignore included languages
osTicket/upload/include/i18n/*

# Ignore images and other assets
osTicket/upload/images/*

# on phar customization folder ignore verything other than extract repack
/phar_customization*
!/phar_customization/extract.php
!/phar_customization/repack.php
